{
  "name": "n8n-nodes-rdsc",
  "version": "0.0.1",
  "description": "n8n nodes for RD Station Conversas",
  "author": {
    "name": "Resultados Digitais",
    "email": "ia@rdstation.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ResultadosDigitais/n8n-nodes-rdsc.git"
  },
  "homepage": "https://github.com/ResultadosDigitais/n8n-nodes-rdsc#readme",
  "bugs": {
    "url": "https://github.com/ResultadosDigitais/n8n-nodes-rdsc/issues"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "rd-station",
    "rd-station-conversas",
    "whatsapp"
  ],
  "license": "MIT",
  "type": "commonjs",
  "main": "dist/nodes/RdConversas/RdConversas.node.js",
  "scripts": {
    "build": "n8n-node build",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "n8n-node prerelease"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "nodes": [
      "dist/nodes/RdConversas/RdConversas.node.js",
      "dist/nodes/RdConversasTrigger/RdConversasTrigger.node.js"
    ],
    "credentials": [
      "dist/nodes/RdConversas/RdConversasApi.credentials.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "0.23.1",
    "@types/node": "20.10.0",
    "eslint": "9.29.0",
    "n8n-workflow": "2.13.1",
    "release-it": "19.2.4",
    "typescript": "5.3.3"
  },
  "overrides": {
    "eslint": "9.29.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
