{
	"name": "n8n-nodes-rdsc",
	"version": "0.0.1",
	"description": "n8n community node for RD Station Conversas",
	"author": {
		"name": "Resultados Digitais",
		"email": "ia@rdstation.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ResultadosDigitais/n8n-nodes-rdsc.git"
	},
	"homepage": "https://github.com/ResultadosDigitais/n8n-nodes-rdsc#readme",
	"bugs": {
		"url": "https://github.com/ResultadosDigitais/n8n-nodes-rdsc/issues"
	},
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"rd-station",
		"rd-station-conversas"
	],
	"license": "MIT",
	"type": "commonjs",
	"main": "dist/nodes/RdStationConversas/RdStationConversas.node.js",
	"scripts": {
		"build": "n8n-node build",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
